li_output)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"d7RbSmSfY9Ki","executionInfo":{"status":"ok","timestamp":1784187593931,"user_tz":-330,"elapsed":16882,"user":{"displayName":"Soumili Jana","userId":"12041607047683083934"}},"outputId":"d1c6cce5-286c-4bca-eab6-196ff111a0b9"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Generated: /content/drive/MyDrive/Colab Notebooks/Voice_Project/outputs/mms/english/english.wav\n","Generated: /content/drive/MyDrive/Colab Notebooks/Voice_Project/outputs/mms/arabic/arabic.wav\n","Generated: /content/drive/MyDrive/Colab Notebooks/Voice_Project/outputs/mms/hindi/hindi.wav\n","Generated: /content/drive/MyDrive/Colab Notebooks/Voice_Project/outputs/mms/bengali/bengali.wav\n"]}]},{"cell_type":"code","source":["# Round-Trip WER(Intelligibility)\n","!pip install -q faster-whisper jiwer\n","from faster_whisper import WhisperModel\n","from jiwer import wer\n","device=\"cuda\" if torch.cuda.is_available() else \"cpu\"\n","compute_type=\"float16\" if device==\"cuda\" else \"int8\"\n","asr_model = WhisperModel(\"large-v3\", device=device, compute_type=compute_type)\n","def transcribe(audio_path):\n","  segments,_=asr_model.transcribe(audio_path)\n","  return \" \".join([seg.text for seg in segments]).strip()\n","mms_wer_results=[]\n","\n","for lang,text,audio_path in[\n","    (\"English\",text_en,mms_english_output),\n","    (\"Arabic\",text_ar,mms_arabic_output),\n","    (\"Hindi\",text_hi,mms_hindi_output),\n","    (\"Bengali\",text_bn,mms_bengali_output),\n","]:\n","    transcribed=transcribe(audio_path)\n","    error=wer(text,transcribed)\n","    print(f\"\\n{lang} (MMS-TTS):\")\n","    print(\"Original: \",text)\n","    print(\"Transcribed: \",transcribed)\n","    print(f\"WER: ,{error*100:.2f}%\")\n","    mms_wer_results.append({\"language\":lang,\"model\": \"MMS-TTS\", \"original\":text,\"transcribed\":transcribed,\"wer\":round(error,4)})"],"metadata":{"colab":{"base_uri":"http